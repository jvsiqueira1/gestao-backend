{
  "name": "gestao-de-gastos-backend",
  "version": "2.0.0",
  "description": "Backend single-user para gestão financeira pessoal",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon index.js",
    "start": "prisma generate && node index.js",
    "build": "prisma generate && node --check index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "db:seed": "node scripts/seed.js",
    "db:dump": "node scripts/dump.js",
    "db:restore": "node scripts/restore.js",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "format": "prettier --write ."
  },
  "type": "commonjs",
  "dependencies": {
    "@prisma/client": "^6.11.1",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^17.0.1",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "lru-cache": "^11.1.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "nodemon": "^3.1.10",
    "prettier": "^3.2.5",
    "prisma": "^6.11.1"
  }
}
